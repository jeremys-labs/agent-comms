<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jeremylahners.agent-comms-a2a-gateway</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Volumes/Repo-Drive/src/agent-comms/scripts/start-a2a-gateway.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Volumes/Repo-Drive/src/agent-comms</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>/Users/jeremylahners</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>/Volumes/Repo-Drive/src/agent-comms/logs/a2a-gateway.log</string>

  <key>StandardErrorPath</key>
  <string>/Volumes/Repo-Drive/src/agent-comms/logs/a2a-gateway.err.log</string>
</dict>
</plist>
